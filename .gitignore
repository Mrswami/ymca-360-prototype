# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase Configurations — Contain project-specific keys, generated by FlutterFire CLI
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist
/macos/Runner/GoogleService-Info.plist
/lib/firebase_options.dart

# Node / Functions dependencies — never commit node_modules
functions/node_modules/

# Local developer secrets (Stripe keys, etc.) — never commit these
.env
.env.local
*.env
